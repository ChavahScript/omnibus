{
  "name": "@ceo-office/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "native:sync": "expo prebuild --platform ios --no-install && cd ios && pod install",
    "ios:pods": "cd ios && pod install",
    "ios:verify": "fastlane ios verify",
    "ios:archive": "fastlane ios archive",
    "ios:testflight:check": "fastlane ios check_testflight_access",
    "ios:testflight": "fastlane ios upload_testflight",
    "assets:icon": "node scripts/generate-app-icon.mjs",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "ceo-office-haptics": "file:modules/haptics",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "^17.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-dev-client": "^6.0.0",
    "expo-modules-core": "^3.0.0",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.8.3"
  },
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  }
}
