# Network and secure pairing
PORT=8787
# Leave blank to persist a random workspace-local requested name. That keeps
# the public relay origin stable across normal reconnects so a paired iPhone
# can resume after moving between Wi-Fi and cellular. Set an explicit value
# only when you need an owner-chosen localtunnel name.
TUNNEL_SUBDOMAIN=
# All relative paths are rooted in the terminal's current project directory,
# never in the global npm installation directory.
WORKSPACE_ROOT=.
HOST_EXECUTION_ENABLED=false

# Keep the laptop awake while an Omnibus coordinator or Home Fleet worker is
# serving. This uses a user-scoped platform helper only; it never changes the
# system power plan and stops on Ctrl+C/normal shutdown. Set false when battery
# preservation matters more than continuous availability.
OMNIBUS_KEEP_AWAKE=true

# Developer agent. Local Ollama is the default and requires no API key. Select
# codex-cli or responses only when the owner wants to use that provider.
DEVELOPER_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
CODEX_COMMAND=codex

# Optional observational pricing for the Responses provider. These values are
# never used to block a command; omit or leave at zero when they are unknown.
OPENAI_INPUT_USD_PER_MILLION=0
OPENAI_OUTPUT_USD_PER_MILLION=0
MAX_DEVELOPER_OUTPUT_TOKENS=6000

# Auditor and default Developer stay on local compute. The same efficient model
# can power both roles, or assign a larger developer model on a stronger laptop.
# On Windows, install Ollama through its official interactive installer first.
# The bridge only probes `ollama` on PATH and Ollama's standard per-user install
# location; it never downloads, executes, or scripts a Windows installer.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
OLLAMA_DEVELOPER_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
OLLAMA_NUM_CTX=32768
# Optional. Set this as a user environment variable before starting Ollama when
# models need a different drive. On Windows, restart the Ollama tray app and
# open a new terminal after changing it. Leave blank for Ollama's default.
OLLAMA_MODELS=

# Optional Home Fleet (spare laptops on one trusted private LAN). The paired
# phone cannot change these owner-side values. Workers never use the public
# tunnel and accept only signed bounded peer-review text.
HOME_FLEET_COORDINATOR_PORT=8791
HOME_FLEET_WORKER_PORT=8792
# Optional concrete RFC1918 IPv4 address for a multi-adapter laptop. Leave
# blank to select a local Wi-Fi/Ethernet private address automatically.
HOME_FLEET_BIND_HOST=
HOME_FLEET_MAX_WORKERS=4
# The worker command pulls this small fixed local peer-review model only after
# terminal confirmation. A stronger laptop owner may set another local tag.
HOME_FLEET_WORKER_MODEL=qwen2.5-coder:1.5b
HOME_FLEET_WORKER_NUM_CTX=8192
# How long a worker keeps its review model resident after accepting the
# coordinator's opt-in context bundle. Idle workers without a bundle still
# unload after every review. Residency is what lets a shared pre-computed
# prompt prefix cut review time-to-first-token.
HOME_FLEET_WORKER_KEEP_ALIVE=10m

# Optional cited web research. It is off by default and must be approved for
# each individual idea from the paired phone. Only that idea text is sent to
# Brave Search; workspace files, local memory, and audit history never leave
# the laptop through this feature. The key is sent only as the HTTPS provider
# authentication header, never to the phone, a model prompt, or local audit.
WEB_RESEARCH_ENABLED=false
WEB_RESEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
WEB_RESEARCH_MAX_RESULTS=5
WEB_RESEARCH_TIMEOUT_MS=12000
WEB_RESEARCH_QUERY_MAX_CHARS=400
WEB_RESEARCH_MAX_CONTENT_CHARS=5000

# A small persisted FIFO absorbs a short burst from paired devices. Jobs run
# serially and remain local. After a bridge restart, a fresh paired-device
# confirmation is required before any prior request can run again.
QUEUE_MAX_PENDING=12
QUEUE_MAX_ATTEMPTS=3
QUEUE_RETRY_BASE_MS=1500

# A bounded source map helps the local Auditor understand this workspace. It
# never reads symlinks, hidden/VCS/dependency folders, or likely secrets, and
# is supplied only when both Auditor and Developer remain loopback/local.
WORKSPACE_CONTEXT_MAX_FILES=24
WORKSPACE_CONTEXT_MAX_SNIPPETS=4
WORKSPACE_CONTEXT_MAX_CHARS=8000

# Second Brain: the persistent local knowledge layer. A bi-temporal knowledge
# graph under .omnibus/state/brain records distilled facts from ideas, briefs,
# git activity, and diagnostics; HippoRAG-style retrieval recalls them for new
# ideas; the Code Digital Twin remembers bug fixes and validates code against
# structured anti-patterns. Everything stays on this laptop. Set false to run
# the original stateless workflow.
#
# ADAPTIVE SIZING: capacity knobs left unset are sized to this laptop's
# physical memory (compact <12 GB, balanced <24 GB, power <48 GB, studio
# beyond), covering OLLAMA_NUM_CTX, the OMNIBUS_BRAIN_* limits below,
# OMNIBUS_AMBIENT_GIT_POLL_MS, and HOME_FLEET_WORKER_KEEP_ALIVE. Setting a
# variable explicitly always wins. `omnibus-bridge doctor` prints the tier.
OMNIBUS_SECOND_BRAIN=true
# Read-only `git status/diff --stat` polling of the workspace. It never runs
# hooks or writes; a non-git workspace simply reports the watcher unavailable.
OMNIBUS_AMBIENT_GIT_POLL_MS=45000
# Optional diagnostics command (for example "npx tsc --noEmit"). Split on
# whitespace and spawned without a shell; ambient diagnostics stay off until
# the owner explicitly names a command here.
OMNIBUS_AMBIENT_CHECK_COMMAND=
OMNIBUS_AMBIENT_CHECK_INTERVAL_MS=300000
OMNIBUS_BRAIN_MAX_NODES=4000
OMNIBUS_BRAIN_MAX_FACTS=12000
OMNIBUS_BRAIN_RETRIEVAL_TOP_K=12
OMNIBUS_BRAIN_RETRIEVAL_MAX_CHARS=4000

# Third, independent Home Fleet consent: when true the coordinator may share
# ONE redacted, content-addressed knowledge bundle (distilled facts and the
# anti-pattern digest — never raw files, memory, credentials, or audit
# records) with approved workers, so their local models keep a warm prompt
# prefix and answer peer reviews with a lower time-to-first-token. Workers
# exchange the bundle peer-to-peer over the same authenticated private LAN.
# Off by default: the fleet then remains idea-text-only exactly as before.
HOME_FLEET_CONTEXT_SHARING=false

# Shift-left pre-commit gate (installed with `omnibus-bridge hook install`).
# Mechanical anti-pattern detectors block and can auto-correct; the optional
# local-model layer is advisory only and fails open.
OMNIBUS_PRECOMMIT_TIMEOUT_MS=15000
OMNIBUS_PRECOMMIT_LLM=false

# Optional Higgsfield CLI integration. The app can request a job after a local
# confirmation; a completed job writes an owner-review handoff under
# .omnibus/state/marketing/. It never auto-publishes to social networks.
HIGGSFIELD_COMMAND=higgsfield
HIGGSFIELD_EXECUTION_ENABLED=false
HIGGSFIELD_SOUL_ID=
AUDIT_DIR=.omnibus/audit
STATE_DIR=.omnibus/state
