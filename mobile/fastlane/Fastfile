default_platform(:ios)
require "shellwords"

# Omnibus uses Xcode-managed signing for the first TestFlight build. It is
# intentionally lean for a hackathon: the owner signs in to Xcode once, then
# Fastlane archives and uploads with an App Store Connect API key. A shared CI
# configuration can add match + a team API key later without changing the app.
platform :ios do
  MOBILE_DIR = File.expand_path("..", __dir__)
  IOS_DIR = File.join(MOBILE_DIR, "ios")
  XCODEPROJ = File.join(IOS_DIR, "Omnibus.xcodeproj")
  WORKSPACE = File.join(IOS_DIR, "Omnibus.xcworkspace")
  SCHEME = "Omnibus"
  ARTIFACTS_DIR = File.join(MOBILE_DIR, "artifacts/ios")

  def required_environment!(keys)
    missing = keys.select { |key| ENV[key].to_s.strip.empty? }
    UI.user_error!("Missing required environment value(s): #{missing.join(', ')}. Copy fastlane/.env.example to fastlane/.env and fill them in.") unless missing.empty?
  end

  private_lane :validate_native_project do
    UI.user_error!("#{WORKSPACE} is missing. Run `npm run mobile:native-sync` first.") unless File.exist?(WORKSPACE)
    UI.user_error!("#{XCODEPROJ} is missing. Run `npm run mobile:native-sync` first.") unless File.exist?(XCODEPROJ)
  end

  # Supports a narrowly scoped individual key for a local upload. Team keys
  # additionally need ASC_ISSUER_ID; individual keys intentionally omit it.
  private_lane :app_store_api_key do
    required_environment!(%w[ASC_KEY_ID])
    # ASC_KEY_FILE is the documented spelling. Retain ASC_KEY_FILEPATH so an
    # already-created local .env from an earlier setup remains usable.
    key_file = ENV["ASC_KEY_FILE"].to_s.strip
    key_file = ENV["ASC_KEY_FILEPATH"].to_s.strip if key_file.empty?
    UI.user_error!("Missing required environment value: ASC_KEY_FILE") if key_file.empty?
    key_path = File.expand_path(key_file)
    UI.user_error!("App Store Connect key not found at #{key_path}") unless File.file?(key_path)

    options = {
      key_id: ENV.fetch("ASC_KEY_ID"),
      key_filepath: key_path,
      duration: 1_200
    }
    issuer_id = ENV["ASC_ISSUER_ID"].to_s.strip
    options[:issuer_id] = issuer_id unless issuer_id.empty?
    app_store_connect_api_key(**options)
  end

  private_lane :build_release_archive do
    validate_native_project
    required_environment!(%w[APPLE_TEAM_ID])

    # -allowProvisioningUpdates lets Xcode use the signing identity selected by
    # the owner in the workspace. It cannot replace that one-time Xcode sign-in.
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_options: {
        "signingStyle" => "automatic",
        "teamID" => ENV.fetch("APPLE_TEAM_ID")
      },
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
      export_xcargs: "-allowProvisioningUpdates",
      output_directory: ARTIFACTS_DIR,
      output_name: "Omnibus.ipa"
    )
  end

  desc "Regenerate Expo native files and install pods after an app-config or native-module change"
  lane :native_sync do
    sh("cd #{MOBILE_DIR.shellescape} && npx expo prebuild --platform ios --no-install")
    pods
  end

  desc "Install the iOS CocoaPods dependencies without regenerating native files"
  lane :pods do
    sh("cd #{IOS_DIR.shellescape} && pod install")
  end

  desc "Compile an unsigned simulator build; safe before Apple account setup"
  lane :verify do
    validate_native_project
    # Native package upgrades can leave incompatible objects in DerivedData.
    # A scoped Xcode clean makes this simulator gate deterministic without
    # touching the signed archive or user source files.
    sh("xcodebuild -workspace #{WORKSPACE.shellescape} -scheme #{SCHEME.shellescape} -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -quiet clean build CODE_SIGNING_ALLOWED=NO")
  end

  desc "Create a signed App Store IPA locally; does not upload it"
  lane :archive do
    build_release_archive
  end

  desc "Confirm App Store Connect credentials and the registered app without building or uploading"
  lane :check_testflight_access do
    required_environment!(%w[APP_IDENTIFIER])
    api_key = app_store_api_key
    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    latest_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER"),
      version: version,
      initial_build_number: 0
    )
    UI.success("App Store Connect access confirmed for #{ENV.fetch('APP_IDENTIFIER')} (latest TestFlight build: #{latest_build_number}).")
  end

  desc "Archive and upload the next unique build to internal TestFlight"
  lane :upload_testflight do
    # Expo generates the native module provider. Syncing here prevents a JS
    # module from being shipped before its native registration reaches Release.
    native_sync
    required_environment!(%w[APP_IDENTIFIER])
    api_key = app_store_api_key
    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    next_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER"),
      version: version,
      initial_build_number: 0
    ) + 1

    # native_sync can reset the native build number from app.json, while every
    # TestFlight upload must grow past the latest App Store Connect build.
    increment_build_number(xcodeproj: XCODEPROJ, build_number: next_build_number.to_s)
    build_release_archive

    upload_to_testflight(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER"),
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      changelog: ENV.fetch("TESTFLIGHT_CHANGELOG", "Omnibus hackathon demo build."),
      distribute_external: false,
      skip_waiting_for_build_processing: true
    )
  end
end
