# Match this to the explicit App ID you create in the Apple Developer portal.
APP_IDENTIFIER=com.app.omnibus

# Apple Developer Program team ID (10-character value shown in your account).
APPLE_TEAM_ID=YOUR_TEAM_ID

# A local Individual App Store Connect API key is sufficient for this workflow.
# Team API keys also work; add ASC_ISSUER_ID only for a Team key.
ASC_KEY_ID=YOUR_KEY_ID
ASC_KEY_FILE=/absolute/path/outside-this-repository/AuthKey_YOUR_KEY_ID.p8
# ASC_KEY_FILEPATH is also accepted for compatibility with earlier local setup.
# ASC_ISSUER_ID=YOUR_ISSUER_UUID

# Optional release note visible to internal testers.
TESTFLIGHT_CHANGELOG=Omnibus hackathon demo build.
